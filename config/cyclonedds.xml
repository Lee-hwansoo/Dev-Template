<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <Domain id="any">
        <General>
            <!--
                By default, bridge networks drop DDS UDP Multicast packets.
                This setting allows the discovery to proceed without explicitly
                crashing, while the fallback node pairs via the Unicast Peers configuration below.
            -->
            <AllowMulticast>default</AllowMulticast>
        </General>
        <Discovery>
            <Peers>
                <!--
                    Unicast Discovery Proxy: Automatically pair local nodes (Host/Container mapping)
                    that are cut off from IGMP Multicast. Add more external IP addresses here
                    for multi-robot operation over VPNs or isolated subnets.
                -->
                <Peer address="localhost"/>
            </Peers>
            <ParticipantIndex>auto</ParticipantIndex>
        </Discovery>
    </Domain>
</CycloneDDS>
